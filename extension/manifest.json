{
  "manifest_version": 3,
  "name": "beautyhotel 房價同步",
  "short_name": "房價同步",
  "version": "1.0.9",
  "description": "在 Google Travel 頁面一鍵抓取飯店 3 OTA 房價，匯入到 hotelbchic.github.io/beautyhotel 比價表。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "beautyhotel 房價同步",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.google.com/travel/*",
    "https://hotelbchic.github.io/beautyhotel/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/travel/*"],
      "js": ["content-google.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hotelbchic.github.io/beautyhotel/*"],
      "js": ["content-bh.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
